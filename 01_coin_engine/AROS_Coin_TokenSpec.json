[
  {
    "token": {
      "name": "AROS Coin",
      "symbol": "ARO",
      "decimals": 8,
      "totalSupply": "dynamic",
      "supplyMechanism": {
        "type": "transaction-amount-emission-1:1",
        "initialSupply": 0,
        "mintOn": "verified_transaction",
        "burnOn": "transaction_completion",
        "emissionFormula": "emissionAmount = transactionAmount",
        "burnFormula": "burnAmount = emissionAmount (net circulating change = 0)"
      }
    },
    "governance": {
      "issuer": "AST Core Protocol",
      "modificationRules": {
        "changeDecimals": false,
        "changeSymbol": false,
        "changeSupplyMechanism": "via_smart_contract_vote"
      }
    },
    "commission": {
      "defaultRate": 0.005,
      "rateUnit": "fraction",
      "formula": "commission = transactionAmount * rate",
      "distribution": {
        "nodePool": 0.75,
        "afcReserve": 0.25
      },
      "nodePoolAddress": "SYSTEM_NODE_POOL_00000000000000000000",
      "afcReserveAddress": "SYSTEM_AFC_RESERVE_000000000000000000"
    },
    "afcReservePriceIndex": {
      "formula": "reserveIndex = 1.0 + sqrt(totalAfcReserve) / 10000",
      "description": "Monotonically rising — every subsequent emission is priced higher as AFC reserve accumulates"
    },
    "compatibility": {
      "blockchain": "AST_NodeChain",
      "wallets": ["AST Wallet", "CrossChainWrapper"],
      "bridgeable": true
    },
    "security": {
      "auditTrail": true,
      "signedPayloads": true,
      "immutability": true
    },
    "metadata": {
      "version": "2.0.0",
      "lastUpdated": "2026-05-19",
      "contractRef": "src/token/emission.service.ts",
      "canonicalSpec": "01_coin_engine/coin_emission_model.md"
    }
  }
