{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aros.ast/schemas/risk_score.schema.json",
  "title": "RiskScore",
  "type": "object",
  "required": ["subject", "score", "source", "ts"],
  "properties": {
    "subject": { "type": "string" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "source": { "type": "string", "enum": ["ALB", "AST", "AI_AGENT"] },
    "ts": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

