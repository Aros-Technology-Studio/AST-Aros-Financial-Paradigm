{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aros.ast/schemas/transaction.schema.json",
  "title": "Transaction",
  "type": "object",
  "required": ["txId", "createdAt", "shardId", "from", "to", "amount", "ttl", "signature"],
  "properties": {
    "txId": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "ttl": { "type": "integer", "minimum": 1 },
    "shardId": { "type": "string", "pattern": "^[a-z0-9-]{1,32}$" },
    "from": { "type": "string", "minLength": 1 },
    "to": { "type": "string", "minLength": 1 },
    "amount": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]{1,9})?$" },
    "meta": { "type": "object", "additionalProperties": true },
    "potWeight": { "type": "number", "minimum": 0 },
    "signature": { "type": "string", "minLength": 64 }
  },
  "additionalProperties": false
}
